# MongoDB connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/tuavec?retryWrites=true&w=majority

# Server port (optional)
PORT=5000

# Base URL for API (used when generating callback URLs for payments)
API_BASE_URL=https://your-app.onrender.com

# Frontend URL (used in emails and order tracking links)
FRONTEND_URL=https://your-frontend-domain.com

# Allowed CORS origins (comma-separated). Example: https://your-frontend-domain.com,https://admin.your-frontend-domain.com
CORS_ORIGINS=https://your-frontend-domain.com

# bKash credentials (obtain from bKash merchant portal)
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh
BKASH_APP_KEY=your_app_key_here
BKASH_APP_SECRET=your_app_secret_here
BKASH_USERNAME=your_username_here
BKASH_PASSWORD=your_password_here

# JWT secret and other keys
JWT_SECRET=replace_with_secure_secret

# NOTE: Never commit your real .env to source control. Use this example as a template.
