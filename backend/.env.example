# =====================================================================
# Tu Avec E-Commerce Platform - Environment Configuration
# =====================================================================
# Copy this file to .env and fill in your actual values

# =====================================================================
# SERVER CONFIGURATION
# =====================================================================
NODE_ENV=development
PORT=5000
BACKEND_URL=https://tuavec.onrender.com/api
FRONTEND_URL=http://localhost:3000

# =====================================================================
# DATABASE
# =====================================================================
MONGODB_URI=mongodb+srv://tuavec_admin:CSPamQfUtjQYDljV@tuavec-db.9sannfw.mongodb.net/tuavec?appName=tuavec-db
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tuavec?retryWrites=true&w=majority

# =====================================================================
# AUTHENTICATION & SECURITY
# =====================================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# =====================================================================
# EMAIL CONFIGURATION (Gmail)
# =====================================================================
# Steps to get Gmail App Password:
# 1. Enable 2-Factor Authentication on Google Account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate app-specific password for "Mail"
GMAIL_USER=aarianabrar3@gmail.com
GMAIL_APP_PASSWORD=ainp vidk qmeh bzmt
ADMIN_EMAIL=aarianabrar3@gmail.com

# =====================================================================
# SMS CONFIGURATION (Twilio - Optional)
# =====================================================================
# Sign up at https://www.twilio.com/
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE=+1234567890

# =====================================================================
# PAYMENT GATEWAY - SSLCommerz
# =====================================================================
# Register at https://sslcommerz.com/
# For testing use sandbox mode, for production use live credentials

# Test (Sandbox) Credentials:
SSLCOMMERZ_STORE_ID=tuavec
SSLCOMMERZ_STORE_PASSWORD=test-password

# Production Credentials (replace with your actual credentials):
# SSLCOMMERZ_STORE_ID=your-store-id
# SSLCOMMERZ_STORE_PASSWORD=your-store-password

# =====================================================================
# BKASH PAYMENT GATEWAY (Optional)
# =====================================================================
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh
BKASH_APP_KEY=your_app_key_here
BKASH_APP_SECRET=your_app_secret_here
BKASH_USERNAME=your_username_here
BKASH_PASSWORD=your_password_here

# =====================================================================
# FILE UPLOAD CONFIGURATION
# =====================================================================
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp
UPLOAD_DIR=./uploads

# =====================================================================
# CORS CONFIGURATION
# =====================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:3000

# =====================================================================
# ADMIN CREDENTIALS (For Initial Setup)
# =====================================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123456
ADMIN_EMAIL=admin@tuavec.com

# =====================================================================
# SHIPPING & DELIVERY
# =====================================================================
# Default shipping costs by region (in BDT)
SHIPPING_DHAKA=80
SHIPPING_CHITTAGONG=150
SHIPPING_SYLHET=150
SHIPPING_KHULNA=150
SHIPPING_RAJSHAHI=150
SHIPPING_BARISHAL=150
SHIPPING_RANGPUR=150
SHIPPING_MYMENSINGH=150
FREE_SHIPPING_ABOVE=2000

# =====================================================================
# BUSINESS CONFIGURATION
# =====================================================================
BUSINESS_NAME=Tu Avec
BUSINESS_EMAIL=support@tuavec.com
BUSINESS_PHONE=+8801XXXXXXXXX
BUSINESS_ADDRESS=Bangkok, Thailand
REFUND_DAYS=30
RETURN_DAYS=30

# =====================================================================
# ANALYTICS & TRACKING
# =====================================================================
FACEBOOK_PIXEL_ID=
GOOGLE_ANALYTICS_ID=

# NOTE: Never commit your real .env to source control. Use this example as a template.
